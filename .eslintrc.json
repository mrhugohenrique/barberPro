{
	"root": true,
	"ignorePatterns": [
		"projects/**/*",
		"dist/**/*",
		"node_modules/**/*",
		"package.json",
		"package-lock.json",
		"angular.json",
		"tsconfig*.json",
		".eslintrc.json",
		"prerendered-routes.json"
	],
	"overrides": [
		{
			"files": ["*.ts"],
			"extends": [
				"eslint:recommended",
				"plugin:@typescript-eslint/recommended",
				"plugin:@angular-eslint/recommended",
				"plugin:@angular-eslint/template/process-inline-templates",
				"prettier"
			],
			"rules": {
				"@angular-eslint/directive-selector": [
					"error",
					{
						"type": "attribute",
						"prefix": "app",
						"style": "camelCase"
					}
				],
				"@angular-eslint/component-selector": [
					"error",
					{
						"type": "element",
						"prefix": "app",
						"style": "kebab-case"
					}
				]
			}
		},
		{
			"files": ["*.html"],
			"extends": [
				"eslint:recommended",
				"plugin:@typescript-eslint/recommended",
				"plugin:@angular-eslint/recommended",
				"plugin:@angular-eslint/template/process-inline-templates",
				"prettier"
			],
			"rules": {}
		}
	]
}
